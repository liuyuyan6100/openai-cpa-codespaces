@@ -141,6 +145,85 @@ class Sub2APIClient:
     def _get_push_settings(self) -> Dict[str, Any]:
         return get_sub2api_push_settings()
 
+    def _has_admin_jwt_config(self) -> bool:
+        return bool(str(getattr(cfg, "SUB2API_ADMIN_EMAIL", "")).strip() and str(getattr(cfg, "SUB2API_ADMIN_PASSWORD", "")).strip())
+
+    def _build_auth_headers(self, use_bearer: bool = True) -> Dict[str, str]:
+        headers = {"Content-Type": "application/json"}
+        if use_bearer:
+            token = str(getattr(cfg, "SUB2API_ACCESS_TOKEN", "")).strip()
+            if token:
+                headers["Authorization"] = f"Bearer {token}"
+                return headers
+        headers["x-api-key"] = self.api_key
+        return headers
+
+    def _persist_login_tokens(self, payload: Any) -> bool:
+        data = payload.get("data", payload) if isinstance(payload, dict) else {}
+        access_token = str(data.get("access_token", "")).strip() if isinstance(data, dict) else ""
+        refresh_token = str(data.get("refresh_token", "")).strip() if isinstance(data, dict) else ""
+        if not access_token:
+            return False
+        setattr(cfg, "SUB2API_ACCESS_TOKEN", access_token)
+        if refresh_token:
+            setattr(cfg, "SUB2API_REFRESH_TOKEN", refresh_token)
+        return True
+
+    def _login_admin(self) -> Tuple[bool, str]:
+        if not self._has_admin_jwt_config():
+            return False, "missing Sub2API admin credentials"
+        url = f"{self.api_url}/api/v1/auth/login"
+        payload = {
+            "email": str(getattr(cfg, "SUB2API_ADMIN_EMAIL", "")).strip(),
+            "password": str(getattr(cfg, "SUB2API_ADMIN_PASSWORD", "")).strip(),
+        }
+        response = cffi_requests.post(url, json=payload, headers={"Content-Type": "application/json"}, timeout=15, impersonate="chrome110", proxies=None)
+        ok, result = self._handle_response(response, success_codes=(200,))
+        if not ok:
+            return False, str(result)
+        if not self._persist_login_tokens(result):
+            return False, "Sub2API login succeeded but access_token missing"
+        return True, "ok"
+
+    def _request(self, method: str, path: str, *, retry_on_401: bool = True, use_bearer: bool = True, **kwargs):
+        headers = kwargs.pop("headers", None) or self._build_auth_headers(use_bearer=use_bearer)
+        request_kwargs = dict(self.request_kwargs)
+        request_kwargs.update(kwargs)
+        response = getattr(cffi_requests, method)(f"{self.api_url}{path}", headers=headers, **request_kwargs)
+        if response.status_code == 401 and retry_on_401 and use_bearer and self._has_admin_jwt_config():
+            login_ok, _ = self._login_admin()
+            if login_ok:
+                headers = self._build_auth_headers(use_bearer=True)
+                response = getattr(cffi_requests, method)(f"{self.api_url}{path}", headers=headers, **request_kwargs)
+        return response
+
+    def _request_absolute(self, method: str, url: str, *, retry_on_401: bool = True, use_bearer: bool = True, **kwargs):
+        headers = kwargs.pop("headers", None) or self._build_auth_headers(use_bearer=use_bearer)
+        request_kwargs = dict(self.request_kwargs)
+        request_kwargs.update(kwargs)
+        response = getattr(cffi_requests, method)(url, headers=headers, **request_kwargs)
+        if response.status_code == 401 and retry_on_401 and use_bearer and self._has_admin_jwt_config():
+            login_ok, _ = self._login_admin()
+            if login_ok:
+                headers = self._build_auth_headers(use_bearer=True)
+                response = getattr(cffi_requests, method)(url, headers=headers, **request_kwargs)
+        return response
+
+    def get_admin_groups(self) -> Tuple[bool, Any]:
+        try:
+            response = self._request("get", "/api/v1/admin/groups/all", timeout=10, impersonate="chrome110")
+            ok, result = self._handle_response(response)
+            if ok and isinstance(result, dict):
+                data = result.get("data", result)
+                return True, data if isinstance(data, list) else []
+            return ok, result
+        except Exception as exc:
+            logger.error("Get Sub2API groups failed: %s", exc)
+            return False, str(exc)
+
+    def _get_push_settings(self) -> Dict[str, Any]:
+        return get_sub2api_push_settings()
+
     def _build_account_extra(self, settings: Dict[str, Any]) -> Dict[str, Any]:
         return _build_account_extra(settings)
 
